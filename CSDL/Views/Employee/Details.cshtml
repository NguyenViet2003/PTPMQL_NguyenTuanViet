@model CSDL.Models.Employee

<h2>Chi tiết nhân viên</h2>

<dl class="row">
    <dt class="col-sm-2">Mã nhân viên:</dt>
    <dd class="col-sm-10">@Model.EmployeeId</dd>
    <dt class="col-sm-2">Họ và tên:</dt>
    <dd class="col-sm-10">@Model.FullName</dd>
    <dt class="col-sm-2">Địa chỉ:</dt>
    <dd class="col-sm-10">@Model.Address</dd>
    <dt class="col-sm-2">Số điện thoại:</dt>
    <dd class="col-sm-10">@Model.PhoneNumber</dd>
    <dt class="col-sm-2">Tuổi:</dt>
    <dd class="col-sm-10">@Model.Age</dd>
</dl>

<p><a asp-action="Index">Quay lại danh sách</a></p>