@model CSDL.Models.Employee

<h2>Tạo mới nhân viên</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="PersonId">PersonId:</label>
        <input asp-for="PersonId" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="EmployeeId">Mã nhân viên:</label>
        <input asp-for="EmployeeId" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="FullName">Họ và tên:</label>
        <input asp-for="FullName" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Address">Địa chỉ:</label>
        <input asp-for="Address" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="PhoneNumber">Số điện thoại:</label>
        <input asp-for="PhoneNumber" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Age">Tuổi:</label>
        <input asp-for="Age" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Tạo</button>
</form>