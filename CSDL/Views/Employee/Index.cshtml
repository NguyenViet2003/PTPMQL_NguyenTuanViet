@model List<CSDL.Models.Employee>

<h2>Danh sách nhân viên</h2>

<p><a asp-action="Create">Tạo mới</a></p>

<table class="table">
    <thead>
        <tr>
            <th>Mã nhân viên</th>
            <th>Họ và tên</th>
            <th>Địa chỉ</th>
            <th>Số điện thoại</th>
            <th>Tuổi</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var employee in Model)
        {
            <tr>
                <td>@employee.EmployeeId</td>
                <td>@employee.FullName</td>
                <td>@employee.Address</td>
                <td>@employee.PhoneNumber</td>
                <td>@employee.Age</td>
                <td>
                    <a asp-action="Details" asp-route-id="@employee.PersonId">Chi tiết</a> |
                    <a asp-action="Edit" asp-route-id="@employee.PersonId">Sửa</a> |
                    <a asp-action="Delete" asp-route-id="@employee.PersonId" onclick="return confirm('Bạn có chắc chắn muốn xóa?')">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>